# Dependencies and build output of the app the workflow scaffolds
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo

# Local env and secrets — never commit these
.env
.env.*
!.env.example

# Keelson worktree-isolated runs check out under the project root
.worktrees/

# Keelson seeds starter command/script assets into the resolved home on first
# CLI use; run from inside this project, that home is .keelson/, so these turn
# up untracked. They aren't part of the sample; keep them out of the build
# commit the finalize node makes.
.keelson/commands/
.keelson/scripts/

# Runtime noise
*.log
.DS_Store
